# ═══════════════════════════════════════════════════════════════════════════
# Bizaira Integrated - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# 🚀 SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000

# 🤖 AI API KEYS
# ─────────────────────────────────────────────────────────────────────────────
# Get your API key from: https://ai.gateway.lovable.dev
# This is required for image and text generation features
# Leave empty to use mock data during development
AI_API_KEY=

# 🗄️ DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string for Drizzle ORM
# Format: postgresql://username:password@localhost:5432/database_name
# Optional for development (mock data will be used if not set)
DATABASE_URL=

# 🔐 SUPABASE CONFIGURATION (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# If you want to switch from the mock Supabase client to a real one:
# These would be needed in the future integration
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ═══════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. LOCAL DEVELOPMENT (With Mock Data):
#    - Leave AI_API_KEY and DATABASE_URL empty
#    - App will work with mocked responses
#    - Good for UI/UX testing
#
# 2. WITH AI INTEGRATION:
#    - Add AI_API_KEY from Lovable.dev
#    - Install Lovable CLI and configure credentials
#    - AI text/image generation will work
#
# 3. WITH DATABASE:
#    - Set up PostgreSQL locally or on cloud (AWS RDS, Render, etc)
#    - Update DATABASE_URL with your connection string
#    - Run Drizzle migrations
#    - User data will be persisted
#
# 4. WITH REAL SUPABASE:
#    - Create Supabase project at https://supabase.com
#    - Copy project URL and anon key
#    - Update supabase client integration code
#    - Real authentication will work
#
# ═══════════════════════════════════════════════════════════════════════════
